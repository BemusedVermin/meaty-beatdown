# Dependencies
node_modules/

# Build / emit output (we run via tsx/vitest and never emit, but just in case)
dist/
build/
*.tsbuildinfo

# Test / tool caches and reports
coverage/
.vitest/
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets
.env
.env.*
!.env.example

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini

# The decision log in notes/ is committed (it's an ADR log in all but name);
# only genuinely throwaway scratch stays out of history.
notes/scratch/

# Rust build output (Cargo.lock IS committed — reproducible builds)
rust/target/

# NOTE: golden/*.json are committed cross-language contract artifacts — do NOT ignore them.
